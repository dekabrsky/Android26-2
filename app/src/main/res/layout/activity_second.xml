<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".SecondActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        tools:ignore="UseSwitchCompatOrMaterialXml">

        <Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:title="@string/article_title"
            android:navigationIcon="@drawable/arrow_back" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="20dp" />

        <TextView
            android:id="@+id/textViewTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Представляем Ослепительную Селесту"
            android:textSize="20dp"
            android:textColor="@color/black"
            android:layout_marginBottom="20dp" />

        <TextView
            android:id="@+id/textViewContent1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Подходите, не стесняйтесь! Сегодня мы представляем…"
            android:textSize="16dp"
            android:textColor="@color/black"
            android:layout_marginBottom="20dp" />

        <ImageView
            android:id="@+id/imageViewArticle"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:scaleType="centerCrop"
            android:src="@drawable/celeste"
            android:layout_marginBottom="20dp" />

        <TextView
            android:id="@+id/textViewContent2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Не каждый день самая яркая звезда Кони-Айленда — Ослепительная Селеста — выступает на улицах Манхэттена. Её шоу начинается с Light Eater: глубокий вдох, освещённый пылающей булавой, покрывает врагов перед ней светом и увеличивает наносимый по ним урон. Затем Селеста окутывает себя призматическим щитом Dazzling Trick — при разрушении он взрывается и накладывает немоту на ближайших противников."
            android:textSize="16dp"
            android:textColor="@color/black"
            android:layout_marginBottom="20dp" />

        <TextView
            android:id="@+id/textViewContent3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Постарайтесь не засмотреться на то, как она грациозно парит в воздухе, или на танец её Radiant Daggers — вы точно пожалеете, если окажетесь под ними, когда они обрушатся сверху. А её запоминающийся финальный номер — Shining Wonder — заставит союзников сказать «ООО!», а врагов — «ААА!»."
            android:textSize="16dp"
            android:textColor="@color/black"
            android:layout_marginBottom="20dp" />

        <Switch
            android:id="@+id/switchButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Прочитано"
            android:textSize="16dp" />

    </LinearLayout>

</ScrollView>